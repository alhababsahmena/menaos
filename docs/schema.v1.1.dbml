// MENAOS — Data Ops & Tracking System
// Database schema — DBML syntax
// Docs: https://dbml.dbdiagram.io/docs
// v1.1 (canonical) · June 2026
//
// This is the authoritative v1.1. It supersedes v1.0 and all prior
// iteration drafts. Production-hardening fixes (High + Medium severity)
// are folded in. Constraints that DBML cannot express (partial unique
// indexes, CHECK constraints, the dispute-chain trigger) are NOT
// silently dropped — they are specified in the "MIGRATION LAYER"
// section at the bottom of this file. The DBML below + that section
// together are the single source of truth.
//
// CHANGES FROM v1.0:
//   * Billing moved from platform level to PROJECT level, priced per
//     TASK TYPE. platform_rates is REMOVED, replaced by project_rates
//     keyed (project_id, task_type_id). New task_types lookup (dynamic,
//     admin-managed). tasks gains task_type_id; tasks.rate_id now points
//     to project_rates.
//   * Currency stays on platforms (one currency per platform). Projects
//     inherit it; project_rates amounts are in the parent platform.currency.
//   * Skills added at USER and PROJECT level: skills lookup + user_skills
//     + project_skills pivots. skill_type buckets dev languages, spoken
//     languages, and domain skills (finance, law, etc.).

// ─── Identity & Access Control ──────────────────────────────────

Table users {
  id uuid [primary key]
  entra_object_id varchar [unique, not null, note: 'Microsoft Entra ID object ID (the oid claim). Immutable per user per tenant. THIS is the SSO login match key — never match on email']
  email varchar [unique, not null, note: 'From Entra. Display and notifications only. NOT the SSO match key — UPNs/emails get reassigned when staff leave']
  first_name varchar [not null, note: 'Entra givenName']
  last_name varchar [not null, note: 'Entra surname. If your directory allows blank surnames for service/single-name accounts, relax to nullable']
  photo_url varchar [note: 'Cached profile photo in object storage (copied from MS Graph at login). NULL = no photo, UI falls back to initials. Never expose raw — generate signed URLs at the API layer, same pattern as task_attachments.storage_url']
  is_active boolean [not null, default: true, note: 'False after deactivation. Login blocked but historical records stay intact']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`, note: 'Bumped on every mutation']
}

Table permissions {
  id uuid [primary key]
  key varchar [unique, not null, note: 'Stable machine identifier checked in code, e.g. tasks.review, financials.view']
  name varchar [not null, note: 'Human-readable label shown in admin UI']
  description text
  resource varchar [not null, note: 'Resource group for UI grouping, e.g. tasks, projects, financials']
}

Table roles {
  id uuid [primary key]
  name varchar [unique, not null, note: 'e.g. Staff, Team Lead, Admin, Management — or any custom role']
  description text
  is_system boolean [not null, default: false, note: 'True for built-in seeded roles. Admins can edit but not delete these']
  is_active boolean [not null, default: true]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

Table role_permissions {
  id uuid [primary key]
  role_id uuid [not null]
  permission_id uuid [not null]
  granted_at timestamp [not null, default: `now()`]
  granted_by uuid [note: 'FK to users.id — admin who granted this. NULL for system-seeded grants']

  indexes {
    (role_id, permission_id) [unique, name: 'uq_role_permissions']
  }
}

Table user_roles {
  id uuid [primary key]
  user_id uuid [not null]
  role_id uuid [not null]
  assigned_at timestamp [not null, default: `now()`]
  assigned_by uuid [note: 'FK to users.id — admin who assigned this. NULL for system-seeded assignments']
  unassigned_at timestamp [note: 'NULL = still active. Set to revoke role — soft removal for audit history']

  indexes {
    (user_id, role_id) [name: 'ix_user_roles_user_role', note: 'Lookup index. ACTIVE-row uniqueness is enforced by a PARTIAL UNIQUE INDEX in the migration layer — see uq_active_user_role in MIGRATION LAYER. Do not rely on app-layer checks alone']
  }
}

Table dashboards {
  id uuid [primary key]
  key varchar [unique, not null, note: 'Stable identifier used by frontend to load the right view, e.g. employee, team_lead, financial']
  name varchar [not null]
  description text
  icon varchar [note: 'Optional icon name for nav menu']
  sort_order integer [not null, default: 0, note: 'Display order in nav menu']
  is_active boolean [not null, default: true]
}

Table role_dashboards {
  id uuid [primary key]
  role_id uuid [not null]
  dashboard_id uuid [not null]
  granted_at timestamp [not null, default: `now()`]
  granted_by uuid [note: 'FK to users.id — admin who granted access. NULL for system-seeded grants']

  indexes {
    (role_id, dashboard_id) [unique, name: 'uq_role_dashboards']
  }
}

// ─── Skills (user + project) ─────────────────────────────────────

Table skills {
  id uuid [primary key]
  key varchar [unique, not null, note: 'Stable machine id checked in code, e.g. python, php, arabic, english, finance, contract_law']
  name varchar [not null, note: 'Human-readable label shown in UI']
  skill_type varchar [not null, note: "development_language | spoken_language | domain. Enforced by CHECK ck_skills_type. 'domain' is the catch-all bucket for non-language expertise (finance, law, etc.). Promote to a skill_categories lookup if admins need to add categories at runtime"]
  description text
  is_active boolean [not null, default: true, note: 'Soft-deprecate without deleting — existing user/project links still resolve']

  indexes {
    (skill_type, name) [unique, name: 'uq_skills_type_name']
  }
}

Table user_skills {
  id uuid [primary key]
  user_id uuid [not null]
  skill_id uuid [not null]
  proficiency varchar [note: 'Optional: beginner | intermediate | expert. Enforced by CHECK ck_user_skills_proficiency when not null']
  assigned_at timestamp [not null, default: `now()`]

  indexes {
    (user_id, skill_id) [unique, name: 'uq_user_skill']
  }
}

Table project_skills {
  id uuid [primary key]
  project_id uuid [not null]
  skill_id uuid [not null]
  is_required boolean [not null, default: true, note: 'Required vs nice-to-have — drives the staffing match between project_skills and user_skills']

  indexes {
    (project_id, skill_id) [unique, name: 'uq_project_skill']
  }
}

// ─── Projects & Platforms ────────────────────────────────────────

Table platforms {
  id uuid [primary key]
  name varchar [not null]
  currency varchar [not null, default: 'USD', note: 'JOD | USD only. Enforced by CHECK ck_platforms_currency. One currency per platform. All project_rates.rate_per_task and tasks.rate_snapshot values under this platform are in this currency. Cross-platform earnings aggregates MUST group by currency or convert — never sum JOD and USD into one figure']
  is_active boolean [not null, default: true]
}

Table task_types {
  id uuid [primary key]
  key varchar [unique, not null, note: 'Stable machine id checked in code, e.g. review, super_review, attempt']
  name varchar [not null, note: 'Display label, e.g. Review Task, Super Review, Attempt']
  description text
  is_active boolean [not null, default: true, note: 'Soft-deprecate without deleting — existing tasks and project_rates using it still resolve. Global lookup: add platform_id here only if platforms need different task-type vocabularies']
}

Table projects {
  id uuid [primary key]
  platform_id uuid [not null]
  name varchar [not null]
  started_at timestamp
  ended_at timestamp
  requires_review boolean [not null, default: false, note: 'If true, every task must be reviewed by a user with tasks.review permission before platform submission']
  is_active boolean [not null, default: true]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

Table project_rates {
  id uuid [primary key]
  project_id uuid [not null]
  task_type_id uuid [not null, note: 'Pricing is per (project, task_type). A project prices only the task types it actually uses']
  rate_per_task decimal [not null, note: 'Payment per accepted task of THIS type on THIS project, in the parent platform.currency']
  effective_from date [not null, note: 'Date this rate started applying']
  effective_to date [note: 'NULL = currently active rate. Closed (set to the day before the new rate) when a new rate is inserted. Windows for one (project, task_type) MUST NOT overlap — enforced by exclusion constraint in MIGRATION LAYER']

  indexes {
    (project_id, task_type_id, effective_from) [name: 'ix_project_rates_lookup']
  }
}

Table project_members {
  id uuid [primary key]
  project_id uuid [not null]
  user_id uuid [not null]
  assigned_at timestamp [not null, default: `now()`]
  unassigned_at timestamp [note: 'NULL = currently active on this project']

  indexes {
    (project_id, user_id) [name: 'ix_project_members_proj_user', note: 'Lookup index. ACTIVE-row uniqueness is enforced by a PARTIAL UNIQUE INDEX in the migration layer — see uq_active_project_member in MIGRATION LAYER']
  }
}

// ─── Operational Logging ─────────────────────────────────────────

Table tasks {
  id uuid [primary key]
  project_id uuid [not null]
  task_type_id uuid [not null, note: 'FK to task_types.id — determines which project_rate applies. Required: a task cannot be priced without a type']
  submitted_by uuid [not null, note: 'FK to users.id — staff member who logged the task']
  external_task_id varchar [not null, note: 'Task ID assigned by the platform. UNIQUE per project — see uq_external_task_per_project in MIGRATION LAYER. Prevents double-logging and double-counted earnings']
  description text [not null, note: 'Free-text body written by staff describing what was done']
  notes text [note: 'Internal notes added by a team lead or admin during review. Never overwrites description']
  time_spent_hours decimal [not null]
  status varchar [not null, default: 'pending', note: 'pending | accepted | rejected | escalated. Enforced by CHECK ck_tasks_status. escalated = dispute is out with the client awaiting response. Round-trip: rejected -> escalated -> (won => accepted | lost => rejected). See dispute_chain_rule']
  reviewed_by uuid [note: 'FK to users.id — reviewer. NULL until reviewed, or always NULL if project.requires_review is false']
  reviewed_at timestamp [note: 'NULL meaning matches reviewed_by']
  rate_id uuid [note: 'FK to project_rates.id — the exact rate row rate_snapshot was taken from. Audit provenance: answers "why was this task paid at this rate" without fragile date-matching. NULL only for legacy rows predating this column']
  rate_snapshot decimal [not null, note: 'Rate frozen at submission time, in the platform.currency. Stable even if project_rates is later edited. Must equal the rate_per_task of the rate_id row at snapshot time']
  submitted_at timestamp [not null, default: `now()`]
  platform_submitted_at timestamp [note: 'When the task was sent to the platform (post-review if required). NULL until that step']
  escalated_at timestamp [note: 'Set when the task enters the escalated state (counter-argument escalated). Drives stale-dispute aging on TL/Management dashboards: "escalated > N days, no outcome". NULL if never escalated']
  version integer [not null, default: 1, note: 'Optimistic-lock counter. The dispute-resolution / status-change action must bump this and reject the write if the version it read no longer matches. Prevents two TLs clobbering one rejected task']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`, note: 'Bumped on every mutation']
}

Table task_attachments {
  id uuid [primary key]
  task_id uuid [not null]
  uploaded_by uuid [not null, note: 'FK to users.id — usually the submitter, but a reviewer can also attach files']
  file_name varchar [not null, note: 'Original filename as uploaded, shown in the UI']
  file_type varchar [not null, note: 'MIME type, e.g. image/png, application/pdf']
  file_size_bytes integer [not null]
  storage_url varchar [not null, note: 'Internal path in object storage. Never expose raw — generate signed URLs at the API layer']
  uploaded_at timestamp [not null, default: `now()`]
}

Table availability_logs {
  id uuid [primary key]
  user_id uuid [not null]
  log_date date [not null, note: 'Calendar date. Use date not timestamp — one log per user per day']
  status varchar [not null, note: 'active | absent | blocked. Enforced by CHECK ck_availability_status']
  note text [note: 'Optional reason, especially for absent and blocked']
  created_at timestamp [not null, default: `now()`]

  indexes {
    (user_id, log_date) [unique, name: 'uq_availability_per_day']
  }
}

Table rejection_categories {
  id uuid [primary key]
  name varchar [not null, note: 'Short label shown in UI, e.g. Quality issue, Missing info']
  description text
  is_active boolean [not null, default: true, note: 'Soft-deprecate without deleting — existing rejections using it still resolve']
}

Table rejections {
  id uuid [primary key]
  task_id uuid [not null, note: 'One rejection per task. A new rejection is only valid when tasks.status = rejected — see dispute_chain_rule and the optional trg_rejection_requires_rejected trigger in MIGRATION LAYER']
  category_id uuid [not null]
  feedback text [not null, note: 'Detailed reason — from platform or written by team lead']
  rejected_at timestamp [not null, default: `now()`]

  indexes {
    task_id [unique, name: 'uq_one_rejection_per_task']
  }
}

Table counter_arguments {
  id uuid [primary key]
  rejection_id uuid [not null, note: 'One counter-argument per rejection at most']
  argument text [not null, note: 'The case being made against the rejection']
  lead_decision varchar [not null, default: 'pending', note: 'pending | rejected | escalated. Enforced by CHECK ck_counter_lead_decision. rejected = TL judged the dispute invalid; task stays rejected (terminal, no dispute row). escalated = TL accepted it, sends to client manually, creates one platform_disputes row and moves tasks.status to escalated']
  reviewed_by uuid [note: 'FK to users.id — team lead who decided. NULL while pending']
  created_at timestamp [not null, default: `now()`]
  decided_at timestamp [note: 'NULL while pending']

  indexes {
    rejection_id [unique, name: 'uq_one_counter_per_rejection']
  }
}

Table platform_disputes {
  id uuid [primary key]
  counter_argument_id uuid [not null]
  outcome varchar [not null, default: 'pending', note: 'pending | won | lost. Enforced by CHECK ck_dispute_outcome. won => TL marks done, tasks.status -> accepted (counts toward earnings like any accept). lost => TL marks done, tasks.status stays rejected. Both terminal']
  recorded_by uuid [note: 'FK to users.id — the TL who logged the platform/client response (no client dashboard exists). NULL while pending']
  submitted_at timestamp [not null, default: `now()`]
  resolved_at timestamp [note: 'NULL while waiting on platform response']
  platform_notes text [note: 'Response/context the platform provided when resolving. Pair with recorded_by for full attribution']

  indexes {
    counter_argument_id [unique, name: 'uq_one_dispute_per_counter']
  }
}

// ─── Business Rules ──────────────────────────────────────────────

Note dispute_chain_rule {
  '''
  The rejection -> counter_argument -> platform_dispute chain may only be
  opened for a task whose status is "rejected". A task that is pending,
  accepted, or escalated can never have a NEW rejections row created.

  One-shot chain, drives tasks.status:

    task.status = rejected
      -> 1 rejection  (only when status = rejected)
        -> at most 1 counter_argument
            lead_decision: pending -> { rejected | escalated }
              - rejected  : dispute invalid. Terminal. No dispute row.
                            task.status stays "rejected".
              - escalated : TL accepted; sends to client MANUALLY.
                            task.status -> "escalated";
                            tasks.escalated_at set;
                            1 platform_disputes row created (pending).
                -> 1 platform_dispute
                    outcome: pending -> { won | lost }
                      - won  : task.status -> "accepted". Counts toward
                               earnings exactly like a normal accept
                               (rate_snapshot x accepted), no special
                               casing in F17. [ASSUMPTION — confirm.]
                      - lost : task.status stays "rejected".

  Round-trip: rejected -> escalated -> (won => accepted | lost => rejected)

  The won/lost -> task.status transition and the version bump are done by
  the same action class that resolves the dispute. All recorded_by /
  reviewed_by on this chain point to the TL — there is no client
  dashboard. Enforcement levels for this rule are listed in the
  MIGRATION LAYER note below.
  '''
}

Note pricing_rule {
  '''
  Billing is project-scoped and per task type.

    rate = active project_rates row for (task.project_id, task.task_type_id)
           as of the task's submit date
           (effective_from <= submit_date AND
            (effective_to IS NULL OR effective_to >= submit_date))

  Task-submit action, atomically inside one transaction:
    1. Resolve the active project_rate for (project_id, task_type_id).
       No active rate => REJECT the submit (no silent default to 0).
    2. Set tasks.rate_id = that row's id.
    3. Copy its rate_per_task into tasks.rate_snapshot.
    rate_id and rate_snapshot must never disagree.

  All amounts are in the parent platform.currency (projects inherit the
  platform currency). Earnings = SUM(rate_snapshot) over accepted tasks,
  grouped by platform.currency. The dispute round-trip (won => accepted)
  counts a won task exactly like a normal accept — its frozen
  rate_snapshot, whatever task type it was, is what counts.
  '''
}

Note MIGRATION_LAYER {
  '''
  DBML cannot express partial unique indexes, CHECK constraints, FK
  cascade policy, exclusion constraints, or triggers. They are NOT
  optional polish — they are part of the v1.1 contract. Implement every
  item below in the Laravel migrations (raw DB::statement where needed).

  --- HIGH severity (must ship in v1.1) ---

  1. Partial unique indexes (replace the dropped app-layer "hope"):
       CREATE UNIQUE INDEX uq_active_user_role
         ON user_roles (user_id, role_id)
         WHERE unassigned_at IS NULL;
       CREATE UNIQUE INDEX uq_active_project_member
         ON project_members (project_id, user_id)
         WHERE unassigned_at IS NULL;

  2. Status / enum CHECK constraints (code must not trust strings):
       ck_tasks_status:
         CHECK (status IN ('pending','accepted','rejected','escalated'))
       ck_availability_status:
         CHECK (status IN ('active','absent','blocked'))
       ck_counter_lead_decision:
         CHECK (lead_decision IN ('pending','rejected','escalated'))
       ck_dispute_outcome:
         CHECK (outcome IN ('pending','won','lost'))
       ck_platforms_currency:
         CHECK (currency IN ('JOD','USD'))
       ck_skills_type:
         CHECK (skill_type IN ('development_language','spoken_language','domain'))
       ck_user_skills_proficiency:
         CHECK (proficiency IS NULL OR
                proficiency IN ('beginner','intermediate','expert'))

  3. Optimistic locking on tasks:
       tasks.version increments on every status-affecting write. The
       dispute-resolution action does:
         UPDATE tasks SET ..., version = version + 1
         WHERE id = ? AND version = ?;
       Zero rows affected => 409 conflict, surfaced to the TL.

  --- MEDIUM severity (strongly recommended for v1.1) ---

  4. external_task_id uniqueness:
       CREATE UNIQUE INDEX uq_external_task_per_project
         ON tasks (project_id, external_task_id);
     (Confirm scope — per-project assumed. Use per-platform if a task id
     is unique across the whole platform instead.)

  5. project_rates non-overlap (rate_snapshot ambiguity guard).
     Postgres exclusion constraint over the active window per
     (project, task_type):
       ALTER TABLE project_rates ADD CONSTRAINT ex_project_rate_no_overlap
       EXCLUDE USING gist (
         project_id   WITH =,
         task_type_id WITH =,
         daterange(effective_from, COALESCE(effective_to, 'infinity'::date), '[]') WITH &&
       );
     (Requires btree_gist. If not on Postgres / can't use this, enforce
     in the rate-change action: close the open row before opening a new
     one, inside a transaction.)

  6. rate_id integrity:
       Ref tasks.rate_id > project_rates.id (declared below).
       The task-submit action sets rate_id AND copies its rate_per_task
       into rate_snapshot atomically, so the two never disagree.
       See pricing_rule.

  7. Dispute-chain precondition trigger (data-integrity defence in depth
     against seeders / bulk imports / admin tools bypassing the action):
       trg_rejection_requires_rejected:
         BEFORE INSERT ON rejections
         => RAISE if (SELECT status FROM tasks WHERE id = NEW.task_id)
            <> 'rejected'.
     Status: RECOMMENDED, not mandatory. Ship it if rejections integrity
     is considered financial-adjacent (it is, via the earnings round-trip).

  --- FK cascade policy (decide per relationship) ---
     Operational/audit data (tasks, rejections, disputes, attachments):
     RESTRICT/NO ACTION on user delete — never cascade-destroy history;
     users are deactivated (is_active=false), not deleted. Lookup parents
     (rejection_categories, platforms, task_types, skills) are
     soft-deprecated via is_active, never hard-deleted, so cascade is moot.
     project_rates: RESTRICT on task_type delete (a priced type in use
     must not vanish); deprecate the task_type via is_active instead.
  '''
}

// ─── References ──────────────────────────────────────────────────

// RBAC
Ref: user_roles.user_id > users.id
Ref: user_roles.role_id > roles.id
Ref: user_roles.assigned_by > users.id
Ref: role_permissions.role_id > roles.id
Ref: role_permissions.permission_id > permissions.id
Ref: role_permissions.granted_by > users.id
Ref: role_dashboards.role_id > roles.id
Ref: role_dashboards.dashboard_id > dashboards.id
Ref: role_dashboards.granted_by > users.id

// Skills
Ref: user_skills.user_id > users.id
Ref: user_skills.skill_id > skills.id
Ref: project_skills.project_id > projects.id
Ref: project_skills.skill_id > skills.id

// Platforms & projects
Ref: projects.platform_id > platforms.id
Ref: project_rates.project_id > projects.id
Ref: project_rates.task_type_id > task_types.id
Ref: project_members.project_id > projects.id
Ref: project_members.user_id > users.id

// Tasks
Ref: tasks.project_id > projects.id
Ref: tasks.task_type_id > task_types.id
Ref: tasks.submitted_by > users.id
Ref: tasks.reviewed_by > users.id
Ref: tasks.rate_id > project_rates.id
Ref: task_attachments.task_id > tasks.id
Ref: task_attachments.uploaded_by > users.id

// Availability
Ref: availability_logs.user_id > users.id

// Rejection & dispute chain
Ref: rejections.task_id - tasks.id
Ref: rejections.category_id > rejection_categories.id
Ref: counter_arguments.rejection_id - rejections.id
Ref: counter_arguments.reviewed_by > users.id
Ref: platform_disputes.counter_argument_id - counter_arguments.id
Ref: platform_disputes.recorded_by > users.id
