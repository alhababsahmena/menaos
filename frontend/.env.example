# MENAOS frontend — copy to frontend/.env. Vite only exposes `VITE_*` to the SPA.

# Base URL of the Django/DRF backend. Used by the apiClient (Prompts 4–5).
VITE_API_BASE_URL=http://localhost:8000/api

# Toggle between the in-memory mock layer and the real network apiClient.
# `true`  → mock layer (default during the static build-out phase, Prompts 1–20)
# `false` → real Django/DRF backend via axios
VITE_USE_MOCKS=true
