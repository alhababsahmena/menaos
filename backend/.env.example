# MENAOS backend environment. Copy to `.env` and fill in real values locally.
# Real secrets never leave the developer's machine; CI/prod inject via the platform.

# --- Database (Postgres 16, psycopg v3) ---
# Credentials are assembled into the connection URL by app/core/config.py.
# Never commit real secrets — this file documents the surface only.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=menaos
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_TEST_DB=menaos_test

# --- Object storage (S3 / MinIO) — signed URLs only ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_BUCKET=menaos
S3_SIGNED_URL_TTL_SECONDS=900

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173

# --- Microsoft Entra (OIDC) — stubbed; not yet wired into auth ---
ENTRA_ISSUER=
ENTRA_AUDIENCE=
ENTRA_JWKS_URL=

# --- App ---
DEBUG=false
