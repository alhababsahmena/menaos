# MENAOS backend — copy to backend/.env and fill in.
# Do NOT commit real secrets.

# --- Django core ---
DJANGO_SECRET_KEY=
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostgreSQL 16) ---
DATABASE_URL=postgres://menaos:menaos@localhost:5432/menaos

# --- Cache (Django DatabaseCache; run `manage.py createcachetable` once) ---
DJANGO_CACHE_TABLE=menaos_cache

# --- JWT (djangorestframework-simplejwt) ---
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# --- OIDC / Microsoft Entra (mozilla-django-oidc) ---
# Match users by `oid` claim, never by email. Wiring lands in a later prompt.
OIDC_RP_CLIENT_ID=
OIDC_RP_CLIENT_SECRET=
OIDC_OP_AUTHORIZATION_ENDPOINT=
OIDC_OP_TOKEN_ENDPOINT=
OIDC_OP_USER_ENDPOINT=
OIDC_OP_JWKS_ENDPOINT=
OIDC_RP_SIGN_ALGO=RS256
OIDC_RP_SCOPES=openid email profile

# --- CORS (SPA origin) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Object storage (S3 / MinIO via django-storages); signed URLs only ---
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
# For MinIO: set the endpoint URL, e.g. http://localhost:9000
AWS_S3_ENDPOINT_URL=
AWS_S3_USE_SSL=True
# 'virtual' for AWS, 'path' for MinIO
AWS_S3_ADDRESSING_STYLE=virtual
